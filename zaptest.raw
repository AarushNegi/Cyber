<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up — ZeroKey</title>
  <link rel="stylesheet" href="/static/style.css">
</head>
<body class="auth-page">
  <div class="card">
    <div class="logo">⬡ ZeroKey</div>
    <h1>Create account</h1>
    <p class="subtitle">Start with a secure passwordless-ready setup</p>

    <div class="field">
      <label for="full_name">Full Name</label>
      <input id="full_name" type="text" placeholder="e.g. Aarush Negi" autocomplete="name">
    </div>

    <div class="field">
      <label for="username">Username</label>
      <input id="username" type="text" placeholder="e.g. aarush_dev" autocomplete="username">
      <p class="hint">Letters, numbers, _ . — (3–32 chars)</p>
    </div>

    <div class="field">
      <label for="mobile">Mobile Number</label>
      <input id="mobile" type="tel" placeholder="e.g. 9876543210" autocomplete="tel">
    </div>

    <div class="field">
      <label for="dob">Date of Birth</label>
      <input id="dob" type="date" autocomplete="bday">
    </div>

    <div class="field">
      <label for="password">Password</label>
      <input id="password" type="password" placeholder="Minimum 8 characters" autocomplete="new-password">
    </div>

    <button class="btn-primary" onclick="signup()">CREATE ACCOUNT</button>

    <p id="msg"></p>

    <div class="footer">
      Already have an account? <a href="/signin">Sign in</a>
    </div>
  </div>

  <script src="/static/auth.js"></script>
</body>
</html>